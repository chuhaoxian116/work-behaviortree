<?xml version="1.0" encoding="UTF-8"?>
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="complete_one_task">

      <!-- 电量充足则直接通过，否则执行充电动作。 -->
      <Fallback name="ensure_battery">
        <BatteryOK battery="{battery}"/>
        <ChargeBattery battery="{battery}"/>
      </Fallback>

      <!-- 电量准备好以后，移动到黑板给出的目标点。 -->
      <MoveTo target="{target}"/>
      <Say text="任务完成"/>

    </Sequence>
  </BehaviorTree>
</root>
